# ── Database ──────────────────────────────────────────────────────────────────
# asyncpg driver prefix is required for SQLAlchemy async engine.
# NAS Postgres is exposed on 5433; adjust host when running inside Docker
# (use the container name, e.g. postgres-1, instead of the NAS LAN IP).
DATABASE_URL=postgresql+asyncpg://brandon:CHANGE_ME@192.168.68.58:5433/life_dashboard

# ── JWT / Auth ────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=CHANGE_ME

# HS256 is sufficient for a single-node local deployment.
JWT_ALGORITHM=HS256

# Access tokens are short-lived; the client silently refreshes using the
# refresh token stored in an httpOnly cookie.
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

# ── Bootstrap ─────────────────────────────────────────────────────────────────
# Used only on first startup when the sentinel user (brandon@life-dashboard.local)
# has the placeholder password_hash '!'. The backend will hash this value with
# argon2 and write it to the DB, then clear the env var from its own config.
# Leave blank after first run (or remove from your actual .env).
BOOTSTRAP_PASSWORD=

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins for the Next.js frontend.
# In production (NAS) both origins are the same Tailscale URL; in local dev
# the frontend runs on 3000.
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# ── App ───────────────────────────────────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=info

# Uvicorn bind address and port (used in the Dockerfile CMD).
HOST=0.0.0.0
PORT=8000
