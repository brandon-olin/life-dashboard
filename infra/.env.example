# ── Database ──────────────────────────────────────────────────────────────────
# Inside Docker the api container reaches postgres-1 via the shared
# life-dashboard network, using the container name as hostname and the
# internal Postgres port (5432), NOT the host-mapped port (5433).
DATABASE_URL=postgresql+asyncpg://brandon:CHANGE_ME@postgres-1:5432/life_dashboard

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=CHANGE_ME
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

# ── Bootstrap ─────────────────────────────────────────────────────────────────
# Only used on first startup when the sentinel user still has password_hash '!'.
# The backend hashes this value, writes it to the DB, and effectively disables
# itself thereafter. Leave blank (or remove) after first successful boot.
BOOTSTRAP_PASSWORD=CHANGE_ME

# ── CORS ──────────────────────────────────────────────────────────────────────
# Your Tailscale hostname. In production the frontend and API share the same
# origin, so only one entry is needed here.
ALLOWED_ORIGINS=https://YOUR_NAS.tailnet-name.ts.net

# ── App ───────────────────────────────────────────────────────────────────────
ENVIRONMENT=production
LOG_LEVEL=info
